{
  "name": "traveler",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "@expo/vector-icons": "^15.1.1",
    "@osamaq/drag-select": "^0.2.0",
    "@rnmapbox/maps": "^10.3.1",
    "drizzle-orm": "^0.45.2",
    "expo": "^56.0.11",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "^56.0.10",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "brand:validate": "node ./scripts/validate-placebook-brand-assets.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "expo lint",
    "db:generate": "drizzle-kit generate"
  },
  "jest": {
    "preset": "jest-expo",
    "resolver": "./node_modules/react-native-worklets/jest/resolver.js",
    "watchman": false,
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.worktrees/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.worktrees/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|expo-modules-core|@expo(nent)?/.*|@expo-google-fonts/.*|expo-router|@react-navigation/.*|react-native-paper|react-native-vector-icons|@expo/vector-icons|react-native-safe-area-context|react-native-screens|react-native-reanimated|react-native-worklets|react-native-element-dropdown|@osamaq/drag-select)/)"
    ],
    "moduleNameMapper": {
      "\\.(css)$": "<rootDir>/__mocks__/styleMock.js",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  },
  "private": true
}
